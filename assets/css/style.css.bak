body {
  background: black;
  color: #00ff66;
  font-family: "Courier New", monospace;
  margin: 0;
}

header {
  display: flex;
  justify-content: space-between;
  padding: 10px;
  border-bottom: 2px solid #00ff66;
}

.title {
  font-size: 20px;
  font-weight: bold;
}

.led-panel {
  display: flex;
  gap: 8px;
}

.led {
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: #003300;
  animation: blink 1s infinite alternate;
}

.led:nth-child(2){animation-delay:.2s;}
.led:nth-child(3){animation-delay:.4s;}
.led:nth-child(4){animation-delay:.6s;}
.led:nth-child(5){animation-delay:.8s;}

@keyframes blink {
  from { background:#003300; }
  to   { background:#00ff66; box-shadow:0 0 8px #00ff66; }
}

nav {
  padding: 8px;
  border-bottom: 1px solid #00ff66;
}

button {
  background: black;
  color: #00ff66;
  border: 1px solid #00ff66;
  margin-right: 6px;
  padding: 6px 10px;
  cursor: pointer;
}

button:hover {
  background: #002200;
}

main {
  padding: 12px;
  min-height: 520px;
}

.tab { display: none; }
.tab.active { display: block; }

pre {
  white-space: pre-wrap;
  font-size: 16px;
}

canvas {
  margin-top: 20px;
  background: #001100;
  border: 1px solid #00ff66;
}

.mvs-image {
  text-align: center;
  margin: 20px 0;
}

footer {
  text-align: center;
  border-top: 1px solid #00ff66;
  padding: 10px;
  font-size: 14px;
}

.visitor-panel {
  background: #001100;
  border: 2px solid #00ff66;
  padding: 12px;
  width: fit-content;
  text-align: center;
  font-family: "Courier New", monospace;
  box-shadow: 0 0 15px #00ff66;
}

.visitor-title {
  font-size: 14px;
  margin-bottom: 6px;
}

.visitor-sub {
  font-size: 12px;
  margin-top: 6px;
  opacity: .8;
}

.digits {
  font-size: 42px;
  letter-spacing: 6px;
  font-weight: bold;
  color: #00ff66;
  text-shadow: 0 0 10px #00ff66;
  transition: transform .2s;
}

.digits.flip {
  transform: scale(1.1);
}


.library {
  padding: 20px;
}

.library h2 {
  text-align: center;
  margin-bottom: 20px;
  text-shadow: 0 0 10px #00ff66;
}

.grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18px;
}

.card {
  background: #001100;
  border: 1px solid #00ff66;
  padding: 10px;
  box-shadow: 0 0 12px #00ff66;
  display: flex;
  flex-direction: column;
}

.card h3 {
  font-size: 14px;
  margin-bottom: 6px;
  text-align: center;
}

.card iframe {
  width: 100%;
  height: 260px;
  border: none;
  background: black;
}

.card a {
  margin-top: 8px;
  text-align: center;
  padding: 6px;
  border: 1px solid #00ff66;
  text-decoration: none;
  color: #00ff66;
  font-size: 13px;
}

.card a:hover {
  background: #002200;
}

/* Responsivo */
@media (max-width: 1000px){
  .grid { grid-template-columns: repeat(2,1fr); }
}

@media (max-width: 600px){
  .grid { grid-template-columns: 1fr; }
}

